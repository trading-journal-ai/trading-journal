# Local SQLite database path.
# The default app path is data/journal.db, so this is optional.
DB_PATH=data/journal.db

# Hosted Turso database for demos/deployments.
# Leave these unset for local SQLite development.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your_turso_token_here

# Massive API key for fetching one-minute OHLCV candles.
# Create .env.local from this file and replace the placeholder.
MASSIVE_API_KEY=your_key_here

# OpenAI API key for generating AI coach reviews.
OPENAI_API_KEY=your_openai_key_here
# Optional model override. Defaults to gpt-5.5 if unset.
# OPENAI_MODEL=gpt-5.5

# Optional local Whisper dictation service.
# See docs/coach/LOCAL_DICTATION.md.
# LOCAL_TRANSCRIPTION_URL=http://127.0.0.1:8788/api/transcribe

# Hosted demo mode. When true, imports are disabled and chart pages use only
# cached/fallback candles, avoiding write activity and external chart API calls.
DEMO_READ_ONLY=false

# Temporary, unlisted data-visualization feedback gallery. This is server-side
# only and must be set during the production build. Leave false unless sharing
# /preview/data-viz, then redeploy after changing the value.
ENABLE_DATA_VIZ_PREVIEWS=false
